{
  "name": "azure-architecture-diagram-builder",
  "version": "1.0.0",
  "description": "Azure architecture diagram builder with official icon library",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "./scripts/dev-all.sh",
    "prebuild": "npm run icons:check",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "dev:avatar": "concurrently --names \"token,vite\" --prefix-colors \"cyan,blue\" \"bash scripts/start-token-server.sh\" \"vite --port 3002 --strictPort\"",
    "demo:record": "node scripts/demo-recording.mjs",
    "pricing:refresh": "cd scripts && bash fetch-multi-region-pricing.sh",
    "icons:check": "node scripts/refresh-azure-icons.mjs --check && node scripts/audit-azure-icons.mjs --check && node mcp-server/scripts/sync-icon-map.mjs --check",
    "icons:sync": "node mcp-server/scripts/sync-icon-map.mjs",
    "icons:audit:v24": "node scripts/audit-azure-icons.mjs --check",
    "icons:refresh:v24": "node scripts/refresh-azure-icons.mjs --apply --download && npm run icons:sync",
    "test": "npm run test:icons && npm run test:arm",
    "test:icons": "npm run icons:check && node mcp-server/scripts/test-catalog.mjs",
    "test:arm": "node scripts/test-arm-extractor.mjs",
    "mcp:build": "cd mcp-server && npm run build",
    "mcp:start": "node mcp-server/dist/index.js"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.17.0",
    "@azure/openai": "^2.0.0",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "@types/dagre": "^0.7.53",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.48.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/dom-to-image": "^2.6.7",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "playwright": "^1.58.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
