  "workflow": [
    { "step": 1, "description": "PIM activation request is triggered by a user in Azure PIM", "services": ["Azure PIM"] },
    { "step": 2, "description": "SRE Agent receives the activation event and begins deterministic validation", "services": ["SRE Agent (aq-main)"] },
    { "step": 3, "description": "Agent queries pim-mcp for pending approvals, user details, group memberships, and role eligibilities", "services": ["SRE Agent (aq-main)", "pim-mcp", "Entra ID"] },
    { "step": 4, "description": "Agent queries Enterprise MCP for additional Graph reads (users, groups, eligibility schedules)", "services": ["SRE Agent (aq-main)", "Enterprise MCP", "Entra ID"] },
    { "step": 5, "description": "Agent validates Jira ticket (exists, active, requester linked, documented)", "services": ["SRE Agent (aq-main)", "Jira Cloud"] },
    { "step": 6, "description": "Agent evaluates all deterministic rules (R001-R044) and calculates allowed duration", "services": ["SRE Agent (aq-main)"] },
    { "step": 7, "description": "Agent sends Adaptive Card to approver in Teams with recommendation (Approve/Reject/Human Review)", "services": ["SRE Agent (aq-main)", "Microsoft Teams"] },
    { "step": 8, "description": "Agent creates Jira audit ticket with full evidence trail", "services": ["SRE Agent (aq-main)", "Jira Cloud"] }
  ],
  "architecturePrompt": "Architecture for a PIM Approver Agent that validates Azure PIM activation requests against deterministic rules and provides Approve/Reject/Human Review recommendations via Adaptive Cards in Teams, with full Jira audit trail."
}