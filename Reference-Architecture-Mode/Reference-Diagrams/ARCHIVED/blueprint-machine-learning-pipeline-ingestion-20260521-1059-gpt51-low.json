  "workflow": [
    {
      "step": 1,
      "description": "The Data Scientist collaborates with Azure Data Factory to design and configure data ingestion and transformation pipelines for machine learning."
    },
    {
      "step": 2,
      "description": "Azure Data Factory ingests raw source data and writes it into Azure Data Lake Storage for large-scale, historical training datasets."
    },
    {
      "step": 3,
      "description": "Azure Data Factory transforms and loads curated feature and label tables into Azure SQL Database for structured model training."
    },
    {
      "step": 4,
      "description": "The Data Scientist defines experiments, training configurations, and datasets in Azure Machine Learning using data from Data Lake and SQL."
    },
    {
      "step": 5,
      "description": "Azure Machine Learning submits training jobs to Azure Machine Learning Compute for scalable, distributed model training."
    },
    {
      "step": 6,
      "description": "Upon completion, Azure Machine Learning Compute reports results back and Azure Machine Learning registers the trained model in its model registry."
    },
    {
      "step": 7,
      "description": "Azure Machine Learning deploys the registered model as a containerized inference service onto Azure Kubernetes Service."
    },
    {
      "step": 8,
      "description": "The Business Application sends prediction requests to Azure API Management, calling the exposed inference API."
    },
    {
      "step": 9,
      "description": "Azure API Management securely routes the incoming inference requests to the model-serving endpoint running on Azure Kubernetes Service, which returns predictions to the Business Application."
    }
  ],
