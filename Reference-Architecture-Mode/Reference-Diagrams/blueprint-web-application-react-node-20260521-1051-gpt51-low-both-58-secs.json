  "workflow": [
    {
      "step": 1,
      "description": "Web Users access the application from their browsers, sending HTTP requests to Azure Content Delivery Network for the React frontend."
    },
    {
      "step": 2,
      "description": "Azure Content Delivery Network serves cached React static assets or forwards requests to Azure Static Web Apps to fetch the latest static files."
    },
    {
      "step": 3,
      "description": "The React frontend running from Azure Static Web Apps calls the backend API via Azure Application Gateway."
    },
    {
      "step": 4,
      "description": "Azure Application Gateway performs HTTP load balancing and routing of API requests to the Node.js backend hosted on Azure App Service."
    },
    {
      "step": 5,
      "description": "The Node.js backend on Azure App Service connects to Azure Database for PostgreSQL to read and write relational application data."
    },
    {
      "step": 6,
      "description": "The Node.js backend stores and retrieves user-uploaded images and other binary files in Azure Blob Storage."
    },
    {
      "step": 7,
      "description": "Azure App Service retrieves application secrets and database connection strings securely from Key Vault at startup or on demand."
    }
