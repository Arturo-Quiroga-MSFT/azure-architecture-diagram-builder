  "workflow": [
    {
      "step": 1,
      "description": "User accesses the React frontend, which is served as static content.",
      "services": [
        "static-web-app"
      ]
    },
    {
      "step": 2,
      "description": "Frontend redirects unauthenticated users to Microsoft Entra ID and receives tokens after login.",
      "services": [
        "static-web-app",
        "entra-id"
      ]
    },
    {
      "step": 3,
      "description": "React frontend calls the Node.js API with the bearer token to perform business operations.",
      "services": [
        "static-web-app",
        "app-service-api",
        "entra-id"
      ]
    },
    {
      "step": 4,
      "description": "Node.js API validates the token with Microsoft Entra ID and retrieves secrets from Key Vault.",
      "services": [
        "app-service-api",
        "entra-id",
        "key-vault"
      ]
    },
    {
      "step": 5,
      "description": "Backend API executes SQL operations against Azure Database for PostgreSQL for core data.",
      "services": [
        "app-service-api",
        "postgres-db"
      ]
    },
    {
      "step": 6,
      "description": "Backend API uploads, reads, or deletes image files in the Storage Account for user content.",
      "services": [
        "app-service-api",
        "blob-storage"
      ]
    },
    {
      "step": 7,
      "description": "Backend API emits logs and metrics to Azure Monitor, which forwards them into Log Analytics for analysis.",
      "services": [
        "app-service-api",
        "azure-monitor",
        "log-analytics"
      ]
    }
  ],
  "architecturePrompt": "A web application with a React frontend, Node.js backend API, PostgreSQL database, and blob storage for images"
}