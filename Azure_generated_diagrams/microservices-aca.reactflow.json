  },
  "workflow": [
    {
      "step": 1,
      "description": "Client request arrives at Front Door (WAF) and is routed to the API Gateway container app.",
      "services": [
        "Front Door",
        "API Gateway"
      ]
    },
    {
      "step": 2,
      "description": "API Gateway dispatches to the appropriate microservice based on the route.",
      "services": [
        "API Gateway",
        "Orders Service",
        "Inventory Service",
        "Payments Service"
      ]
    },
    {
      "step": 3,
      "description": "Services persist transactional and catalog data.",
      "services": [
        "Orders Service",
        "Payments Service",
        "PostgreSQL",
        "Inventory Service",
        "Cosmos DB"
      ]
    },
    {
      "step": 4,
      "description": "Order placement publishes an event to Service Bus; Payments and Inventory consume.",
      "services": [
        "Orders Service",
        "Service Bus",
        "Payments Service",
        "Inventory Service"
      ]
    },
    {
      "step": 5,
      "description": "PaymentCompleted is broadcast via Event Grid back to Orders for status update.",
      "services": [
        "Payments Service",
        "Event Grid",
        "Orders Service"
      ]
    },
    {
      "step": 6,
      "description": "All services emit telemetry to Application Insights, which forwards to Log Analytics.",
      "services": [
        "API Gateway",
        "Application Insights",
        "Log Analytics"
      ]
    }
  ],
  "architecturePrompt": "A microservices application on Azure Container Apps with API gateway, three backend services (orders, inventory, payments), shared PostgreSQL and Cosmos DB, async messaging via Service Bus and Event Grid, secrets in Key Vault, observability via Application Insights and Log Analytics, fronted by Front Door + WAF, with images in Azure Container Registry and CI/CD via GitHub Actions."
