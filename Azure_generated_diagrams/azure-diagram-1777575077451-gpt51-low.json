  "workflow": [
    {
      "step": 1,
      "description": "Client sends an authenticated request; the API gateway validates the access token with the identity provider.",
      "services": [
        "svc-apim",
        "svc-entra"
      ]
    },
    {
      "step": 2,
      "description": "API Management routes the validated API request to the appropriate microservice running in Azure Container Apps.",
      "services": [
        "svc-apim",
        "svc-container-apps"
      ]
    },
    {
      "step": 3,
      "description": "The microservice reads from and writes to Azure Cache for Redis to handle low-latency data and session state.",
      "services": [
        "svc-container-apps",
        "svc-redis"
      ]
    },
    {
      "step": 4,
      "description": "The microservice performs transactional operations against SQL Database and stores or retrieves large objects from the Storage Account.",
      "services": [
        "svc-container-apps",
        "svc-sql-db",
        "svc-storage"
      ]
    },
    {
      "step": 5,
      "description": "For asynchronous workflows, the microservice publishes domain events or commands to Service Bus queues or topics.",
      "services": [
        "svc-container-apps",
        "svc-service-bus"
      ]
    },
    {
      "step": 6,
      "description": "Background worker microservices running in Azure Container Apps receive and process messages from Service Bus.",
      "services": [
        "svc-service-bus",
        "svc-container-apps"
      ]
    },
    {
      "step": 7,
      "description": "Microservices securely fetch configuration and secrets from Key Vault and continuously send telemetry to Azure Monitor, which forwards it to Log Analytics for analysis.",
      "services": [
        "svc-container-apps",
