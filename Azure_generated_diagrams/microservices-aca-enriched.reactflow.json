  "metadata": {
    "architectureName": "Microservices on Azure Container Apps (Enriched)",
    "author": "Arturo Quiroga",
    "version": "1.0",
    "date": "2026-04-30",
    "savedAt": "2026-04-30T19:50:53.453Z"
  },
  "workflow": [
    {
      "step": 1,
      "description": "Internet traffic enters Front Door, is inspected by WAF, and routed to API Management.",
      "services": [
        "Azure Front Door",
        "Web Application Firewall",
        "API Management"
      ]
    },
    {
      "step": 2,
      "description": "API Management authenticates callers via Entra ID and dispatches to the appropriate microservice.",
      "services": [
        "Microsoft Entra ID",
        "API Management",
        "Orders Container Apps",
        "Inventory Container Apps",
        "Payments Container Apps"
      ]
    },
    {
      "step": 3,
      "description": "Microservices retrieve secrets from Key Vault using managed identities and persist data to PostgreSQL or Cosmos DB.",
      "services": [
        "Key Vault",
        "Orders Container Apps",
        "Payments Container Apps",
        "Azure Database for PostgreSQL",
        "Inventory Container Apps",
        "Azure Cosmos DB"
      ]
    },
    {
      "step": 4,
      "description": "Order placement publishes to Service Bus; Payments and Inventory consume to advance the workflow.",
      "services": [
        "Orders Container Apps",
        "Service Bus",
        "Payments Container Apps",
        "Inventory Container Apps"
      ]
    },
    {
      "step": 5,
      "description": "Order lifecycle events fan out via Event Grid to payment subscribers.",
      "services": [
        "Orders Container Apps",
        "Event Grid",
        "Payments Container Apps"
      ]
    },
    {
      "step": 6,
      "description": "GitHub Actions builds images, pushes to ACR, and triggers Container Apps revision rollouts.",
      "services": [
        "GitHub Actions",
        "Container Registry",
        "Orders Container Apps",
        "Inventory Container Apps",
        "Payments Container Apps"
      ]
    },
    {
      "step": 7,
      "description": "All services emit telemetry to Application Insights, which flows through Azure Monitor into Log Analytics.",
      "services": [
        "Orders Container Apps",
        "Inventory Container Apps",
        "Payments Container Apps",
        "Application Insights",
        "Azure Monitor",
        "Log Analytics"
      ]
    }
  ],
  "architecturePrompt": "A microservices application on Azure Container Apps with API gateway, three backend services (orders, inventory, payments), shared PostgreSQL and Cosmos DB, async messaging via Service Bus and Event Grid, secrets in Key Vault, observability via Application Insights and Log Analytics, fronted by Front Door + WAF, with images in Azure Container Registry and CI/CD via GitHub Actions."
}