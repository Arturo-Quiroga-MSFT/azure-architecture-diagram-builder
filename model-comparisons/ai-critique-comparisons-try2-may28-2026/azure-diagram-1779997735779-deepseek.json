        "event-hubs"
      ]
    },
    {
      "step": 3,
      "description": "Event Hubs triggers an Azure Function to process each incoming event.",
      "services": [
        "event-hubs",
        "functions"
      ]
    },
    {
      "step": 4,
      "description": "The Function retrieves secrets (API keys) from Key Vault to call AI services securely.",
      "services": [
        "functions",
        "key-vault"
      ]
    },
    {
      "step": 5,
      "description": "The Function orchestrates calls to Azure OpenAI (text/vision), Speech Services (transcription), and Translator (translation) as needed.",
      "services": [
        "functions",
        "openai",
        "ai-speech",
        "ai-translator"
      ]
    },
    {
      "step": 6,
      "description": "Processed results and raw data are stored: media in Storage Account, metadata and final outputs in Cosmos DB.",
      "services": [
        "functions",
        "storage",
        "cosmosdb"
      ]
    },
    {
      "step": 7,
      "description": "Throughout, App Service and Functions send telemetry to Application Insights, which forwards to Azure Monitor for observability.",
