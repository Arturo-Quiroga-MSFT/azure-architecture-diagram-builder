  "workflow": [
    {
      "step": 1,
      "description": "Patients, clinicians, and EHR clients authenticate before accessing protected healthcare APIs or portal functions.",
      "services": [
        "patient-portal",
        "entra-id"
      ]
    },
    {
      "step": 2,
      "description": "EHR systems submit HL7v2 messages, which are transformed into validated FHIR R4 resources.",
      "services": [
        "azure-functions",
        "fhir-api"
      ]
    },
    {
      "step": 3,
      "description": "FHIR resources are exposed to authorized applications and projected into patient timelines.",
      "services": [
        "fhir-api",
        "patient-timeline-db",
        "patient-portal"
      ]
    },
    {
      "step": 4,
      "description": "PACS systems upload and retrieve radiology studies through DICOMweb while images are retained immutably.",
      "services": [
        "dicom-service",
        "image-storage"
      ]
    },
    {
      "step": 5,
      "description": "Clinical workflows evaluate new patient events, generate decision support, and initiate secure messaging.",
      "services": [
        "logic-apps",
        "azure-functions",
        "patient-portal"
      ]
    },
    {
      "step": 6,
      "description": "Encryption keys protect FHIR, timeline, and imaging data, with security posture continuously assessed.",
      "services": [
        "key-vault",
        "fhir-api",
        "defender-cloud"
      ]
    },
    {
      "step": 7,
      "description": "Application telemetry and every PHI access event are aggregated, retained, and queried for audit and compliance investigations.",
      "services": [
        "azure-functions",
        "azure-monitor",
        "log-analytics"
      ]
    }
  ],
  "architecturePrompt": "A HIPAA-compliant healthcare data platform integrating EHR systems via HL7 FHIR R4 APIs, medical imaging PACS with DICOM support storing 500TB of radiology images, real-time clinical decision support, patient portal with secure messaging, audit logging for all PHI access, disaster recovery with 15-minute RPO, using Azure API for FHIR, Azure Health Data Services for DICOM, Blob Storage with immutable retention for images, Cosmos DB for patient timelines, Azure Functions for HL7v2 to FHIR transformation, Logic Apps for clinical workflows, Key Vault for encryption key management, and Microsoft Defender for Cloud for continuous compliance monitoring",
