  "workflow": [
    {
      "step": 1,
      "description": "An API consumer sends an API call to the platform entry point."
    },
    {
      "step": 2,
      "description": "API Management applies policies (auth, throttling, routing) and forwards the request to the appropriate microservice in Azure Container Apps."
    },
    {
      "step": 3,
      "description": "The microservice retrieves secrets (connection strings, keys) from Azure Key Vault at runtime."
    },
    {
      "step": 4,
      "description": "The microservice reads/writes low-latency shared state via Azure Cache for Redis."
    },
    {
      "step": 5,
      "description": "For asynchronous work, the microservice publishes a message to Azure Service Bus."
    },
    {
      "step": 6,
      "description": "A worker microservice (running on Azure Container Apps) is triggered by Service Bus to process the queued message."
    },
    {
      "step": 7,
      "description": "Azure Container Apps pulls the deployed microservice images from Azure Container Registry."
    },
    {
      "step": 8,
      "description": "Microservices emit platform metrics and signals to Azure Monitor for alerting and health views."
    },
    {
      "step": 9,
      "description": "Azure Monitor routes logs/diagnostics into Log Analytics for centralized querying, troubleshooting, and auditing."
    }
  ],
