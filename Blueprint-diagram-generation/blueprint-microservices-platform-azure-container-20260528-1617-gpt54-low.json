  "workflow": [
    {
      "step": 1,
      "description": "Client applications call the platform APIs through Azure API Management."
    },
    {
      "step": 2,
      "description": "Azure API Management applies gateway policies and routes the request to Azure Container Apps."
    },
    {
      "step": 3,
      "description": "The microservice retrieves secrets and connection settings from Key Vault."
    },
    {
      "step": 4,
      "description": "The application checks Azure Cache for Redis for low-latency cached data or session state."
    },
    {
      "step": 5,
      "description": "The service writes transactional application data to Azure SQL Database."
    },
    {
      "step": 6,
      "description": "The service publishes asynchronous work or domain events to Service Bus."
    },
    {
      "step": 7,
      "description": "A background worker running on Azure Container Apps is triggered from Service Bus to process queued work."
    },
    {
      "step": 8,
      "description": "Azure Container Apps sends platform and application telemetry to Azure Monitor."
    },
    {
      "step": 9,
      "description": "Azure Monitor forwards collected logs and operational data to Log Analytics for analysis and troubleshooting."
    }
